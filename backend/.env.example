# Port the Express server listens on
PORT=5000

# development | production
NODE_ENV=development

# PostgreSQL connection string (e.g. from Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret key used to sign JWTs. Use a long random string in real environments.
JWT_SECRET=changeme

# How long a JWT stays valid before the user must log in again
JWT_EXPIRES_IN=7d

# Gemini API key from https://aistudio.google.com/apikey
# If missing/invalid, AI pre-visit summaries silently fail -- booking is unaffected.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMTP for email notifications. Leave all blank to auto-use a free Ethereal
# test account instead (no signup needed -- emails aren't really delivered,
# but a preview link is logged for each one). Set these to use real SMTP
# (e.g. Gmail with an app password, SendGrid, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@healthcare-manager.local

# Google Calendar OAuth (from Google Cloud Console -- see README for setup steps).
# If missing, calendar sync silently skips -- booking/visit/cancellation are unaffected.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/doctor/google/callback
